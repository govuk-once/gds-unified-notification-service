{
  "name": "gds-unified-notification-service",
  "version": "0.0.0",
  "author": "",
  "type": "module",
  "scripts": {
    "build": "bun scripts/build.ts",
    "build:validate": "tsc",
    "checkov": "checkov --directory . --quiet",
    "commit": "cz",
    "development:organize:tf": "bun scripts/developer-organize-tf.ts",
    "development:sandbox:release:infra": "cd infrastructure/terraform && terraform apply",
    "development:sandbox:release": "npm run build && npm run development:sandbox:release:infra",
    "development:sandbox:setup": "bun scripts/developer-sandbox-setup.ts",
    "cdk:diff": "cd infrastructure/cdk && cdk diff",
    "cdk:checkov": "cd infrastructure/cdk && cdk synth --quiet && checkov --config-file checkov.yaml -d cdk.out --framework cloudformation --compact --quiet",
    "lint:fix": "npx prettier . --write && npx eslint . --fix",
    "lint": "npx prettier . --check && npx eslint .",
    "pre-commit": "VITEST_SILENT=true bun scripts/pre-commit.ts",
    "prepare": "husky",
    "semantic:release": "semantic-release",
    "test:coverage": "vitest run --coverage",
    "test:coverage:detailed": "VITEST_DETAILED_COVERAGE=true vitest run --coverage",
    "test": "vitest",
    "tflint": "terraform fmt -check -diff -recursive && tflint --init && tflint --chdir=infrastructure/terraform  --config .tflint.hcl",
    "tflint:fix": "terraform fmt -recursive",
    "tfsec": "tfsec .",
    "upgrade": "ncu -u -d 'npm run test' && npm audit --omit dev"
  },
  "devDependencies": {
    "@aws-sdk/client-kms": "^3.1030.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.964.0",
    "@aws-sdk/client-sts": "^3.1030.0",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-angular": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@inquirer/prompts": "^8.0.2",
    "@semantic-release/exec": "^7.1.0",
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/bun": "^1.3.4",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.0.3",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "aws-cdk": "^2.1118.0",
    "aws-cdk-lib": "^2.250.0",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "bun": "^1.3.4",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "msw": "^2.12.7",
    "npm-check-updates": "^21.0.1",
    "prettier": "3.7.4",
    "semantic-release": "^25.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@aws-lambda-powertools/jmespath": "^2.29.0",
    "@aws-lambda-powertools/logger": "^2.29.0",
    "@aws-lambda-powertools/metrics": "^2.29.0",
    "@aws-lambda-powertools/parameters": "^2.29.0",
    "@aws-lambda-powertools/parser": "^2.29.0",
    "@aws-lambda-powertools/tracer": "^2.29.0",
    "@aws-lambda-powertools/validation": "^2.29.0",
    "@aws-sdk/client-dynamodb": "^3.964.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@aws-sdk/client-ssm": "^3.956.0",
    "@aws-sdk/credential-providers": "^3.965.0",
    "@aws-sdk/hash-node": "^3.370.0",
    "@aws-sdk/signature-v4": "^3.370.0",
    "@aws-sdk/util-dynamodb": "^3.968.0",
    "@aws-sdk/util-format-url": "^3.965.0",
    "@middy/core": "^6.4.5",
    "@middy/http-error-handler": "^6.4.5",
    "@middy/http-event-normalizer": "^6.4.5",
    "@middy/http-header-normalizer": "^6.4.5",
    "@middy/http-json-body-parser": "^6.4.5",
    "@middy/http-urlencode-body-parser": "^6.4.5",
    "@middy/secrets-manager": "^6.4.5",
    "aws4-axios": "^3.4.0",
    "axios": "^1.15.0",
    "http-errors": "^2.0.1",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog",
      "disableScopeLowerCase": true
    }
  },
  "overrides": {
    "commitizen": {
      "tmp": "^0.2.5"
    },
    "cz-conventional-changelog": {
      "tmp": "^0.2.5"
    }
  }
}
